# Capsule Node — environment template
# Copy to .env and fill in local values. Never commit .env.

# ─── Vault ─────────────────────────────────────────────────────────
# Absolute path to the Obsidian vault this node serves.
# The daemon and plugin both read/write the .capsule/ subdirectory here.
CAPSULE_VAULT_PATH=

# ─── Daemon ports ──────────────────────────────────────────────────
# Localhost-only management API (plugin ↔ daemon). Never expose publicly.
CAPSULE_DAEMON_PORT=7402

# Public agent-facing capsule endpoint. TLS required in production.
CAPSULE_EXTERNAL_PORT=8402

# ─── Runtime ───────────────────────────────────────────────────────
CAPSULE_LOG_LEVEL=info
CAPSULE_MAX_CONCURRENT_COMPUTATIONS=4

# ─── Wallet (do NOT put private keys or mnemonics here) ────────────
# The keyring lives encrypted in $CAPSULE_VAULT_PATH/.capsule/identity/keyring.enc
# and is decrypted in-memory on daemon startup. This env only configures
# which network/address to serve from.
CAPSULE_WALLET_NETWORK=base
CAPSULE_WALLET_ADDRESS=
