{
  "name": "capsule-node-plugin",
  "version": "0.1.0",
  "description": "Obsidian plugin for the Capsule Node — manages capsule notes and the companion daemon.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts",
    "test": "node --import tsx --test src/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/*.test.ts"
  },
  "keywords": [],
  "author": "Ryan Price",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
